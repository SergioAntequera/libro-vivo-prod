# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` no se versiona y suele ser lo primero que falta al mover el proyecto de PC.

# Supabase basico
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
CURRENT_SUPABASE_DB_URL=

# URL base local
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth / OAuth
# Activalos solo despues de configurar el proveedor en Supabase Auth.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_APPLE_ENABLED=false

# Recordatorios de semillas por email
SEED_EVENT_REMINDER_CRON_SECRET=
SEED_EVENT_REMINDER_FROM_EMAIL=
SEED_EVENT_REMINDER_REPLY_TO=
RESEND_API_KEY=

# Media provider
NEXT_PUBLIC_MEDIA_STORAGE_PROVIDER=supabase
MEDIA_STORAGE_PROVIDER=supabase

# Google Drive (solo si usas provider gdrive o uploads gestionados)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
MEDIA_PROXY_SECRET=

# Video / uploads opcionales
NEXT_PUBLIC_MAX_VIDEO_UPLOAD_BYTES=
NEXT_PUBLIC_EXTERNAL_VIDEO_UPLOAD_URL=
NEXT_PUBLIC_EXTERNAL_VIDEO_UPLOAD_FIELD=file

# E2E opcional
E2E_APP_BASE_URL=http://localhost:3000
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
